# Google OAuth 2.0 — Web application client ID from Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client IDs)
# Add authorized JavaScript origins: http://localhost:3000 (and your production URL)
# Multiple IDs (comma-separated) are accepted for token verification; the first is used for Sign in with Google.
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Session signing key — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret

# GitHub Actions (Deploy to Cloud Run) — repository Secrets:
#   GCP_SA_KEY, GCP_PROJECT_ID (or use a Variable for project id), SESSION_SECRET, GOOGLE_CLIENT_ID

# Optional
# PORT=3000

# Session cookie Secure flag: defaults to true when NODE_ENV=production.
# Set to false if you must use HTTP on a non-localhost host (not recommended).
# COOKIE_SECURE=false
