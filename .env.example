# Optional: override the built-in Web client ID (defaults are in src/server/server.js).
# GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Session signing key — required in production / Cloud Run. For local dev, optional if NODE_ENV is not production.
SESSION_SECRET=change-me-to-a-long-random-secret

# GitHub Actions (Deploy to Cloud Run) — repository Secrets: GCP_SA_KEY, SESSION_SECRET
#   GCP_PROJECT_ID — Secret or Variable (OAuth client ID is hardcoded in the app + sync script)

# Optional
# PORT=3000

# Session cookie Secure flag: defaults to true when NODE_ENV=production.
# Set to false if you must use HTTP on a non-localhost host (not recommended).
# COOKIE_SECURE=false
